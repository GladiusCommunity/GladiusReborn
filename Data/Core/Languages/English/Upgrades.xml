    <entry name="HammerOfWrath" value="Hammer of Wrath/Smoke Launcher"/>
	<entry name="HammerOfWrathDescription" value="Grants Hammer of Wrath to Chaos units (Fiends, Obliterator, Helbrute, Defiler, Scorpion, Crawler, Daemon Prince, Warp Claw) and Smokescreen to Defiler, Land Raider and Chaos Rhino."/>

	<entry name="EmperorsClaims" value="Unity of the Emperor"/>
	<entry name="EmperorsClaimsDescription" value="Increases the resource output of non-headquarters buildings of the same type on a tile. Decreases the output of non-headquarters buildings of differing types on a tile."/>

	<entry name="EmperorsSpecialisation" value="In unity there is strength"/>
	<entry name="EmperorsSpecialisationDescription" value="Increases the resource output of non-headquarters buildings of the same type on a tile."/>

	<entry name="SpaceMarines/ResBonus1" value="In unity there is strength"/>
	<entry name="SpaceMarines/ResBonus1Description" value="Increases the resource output of non-headquarters buildings of the same type on a tile."/>

	<entry name="SpaceMarines/ResBonus2" value="Increased collection"/>
	<entry name="SpaceMarines/ResBonus2Description" value="Increases the percent received from outposts."/>

	<entry name="SpaceMarines/UnityDropPod" value="Astartes support"/>
	<entry name="SpaceMarines/UnityDropPodDescription" value="Allows you to summon a Land Raider and Centurion from the Astartes fleet."/>

	<entry name="SpaceMarines/LasCannonDoctrine" value="LasCannon Doctrine"/>
	<entry name="SpaceMarines/LasCannonDoctrineDescription" value="Increases the accuracy of twin linked LasCannons."/>

    <entry name="AwakenTheMachine" value="Support of the Imperium"/>
	<entry name="AwakenTheMachineDescription" value="Enhances the vehicle's awakening effect (+1 accuracy and +1 armor penetration) and grants psykers the ability to curse enemy units."/>
    <entry name="AwakenTheMachineFlavor" value="BaneBlade, Rogal Dorn = +1 max move. Sentinels = +1 max vision. Leman Russ, Devil Dog, Basilisk, Airplanes = +1 armor penetration."/>

	<entry name="AstraMilitarum/Psykers" value="Wyrdvane Psykers"/>
	<entry name="AstraMilitarum/PsykersDescription" value="Psyker unit that specializes in debuffs."/>
	<entry name="AstraMilitarum/PsykersFlavor" value="Wyrdvane Psykers transform the howling might of the Warp into a deadly weapon of Imperial supremacy. They are formed from those Scholastica Psykana inductees not able to control their burgeoning powers without guidance and aid. As individuals, such psykers are unpredictable and unsafe. Yet working in concert, these deadly mutants can be a valuable asset."/>

	<entry name="AstraMilitarum/WeStandTogether" value="We stand together!"/>
    <entry name="AstraMilitarum/WeStandTogetherDescription" value="Increases the group size of Astra Militarum infantry units, except Bullgryns."/>
    <entry name="AstraMilitarum/WeStandTogetherFlavor" value="The campaign’s senior commander has designated the upcoming battle as so vital that they will funnel all of their resources and assets into securing victory, forgoing frugal logistical management in favour of overwhelming force."/>

	<entry name="AstraMilitarum/Scouting" value="Scout specialists"/>
	<entry name="AstraMilitarum/ScoutingDescription" value="Allows Ratlings and Scout Sentinels to reveal tiles in an area around them, and also gives them the ability to move through forests and ruins without penalty."/>

	<entry name="AstraMilitarum/Experienced" value="Experienced Eye"/>
	<entry name="AstraMilitarum/ExperiencedDescription" value="Grants the ability to spot enemy units when attacked by Field Artillery and Tempestus, thereby increasing ranged damage against them."/>

	<entry name="AstraMilitarum/RecoveryGear" value="&lt;string name='Traits/RecoveryGear'/&gt;"/>
	<entry name="AstraMilitarum/RecoveryGearDescription" value="Decrease cooldown from a medpack,increases healing by 4hp from the Omnissiah's Blessing (Tech-Priest) and accelerates the recovery of health points for Astra Militarum units."/>
	<entry name="AstraMilitarum/RecoveryGearFlavor" value="&lt;string name='Traits/RecoveryGearFlavor'/&gt;"/>

	<entry name="AstraMilitarum/VoidShieldGeneratorDescription" value="Grants the ability to upgrade imperial strongpoint and install a void shield generator that provides range damage reduction for allied Astra Militarum units."/>

	<entry name="AstraMilitarum/VoxCaster" value="Relentless"/>
    <entry name="AstraMilitarum/VoxCasterDescription" value="The death of nearby infantry does not reduce morale and enhances the Astra Militarum vehicles, giving them +17% damage."/>

	<entry name="AstraMilitarum/AirDiscipline" value="Air Discipline"/>
    <entry name="AstraMilitarum/AirDisciplineDescription" value="Allows aircraft to receive bonuses from officer and general auras."/>

	<entry name="AstraMilitarum/SkystrikeMissile" value="Heavenly Strike"/>
	<entry name="AstraMilitarum/SkystrikeMissileDescription" value="Gives the Valkyrie the ability to highlight ground targets, increasing infantry damage, deploy Kasrkin and Tempestus giving them +1 max movement and ignor overwatch, and gives the Lightning Strike the ability to fire missiles at air targets."/>
	<entry name="AstraMilitarum/SkystrikeMissileFlavor" value="The not-so-well-known Skystrike support group worked wonders on the battlefield, destroying xenos aircraft and landing strike troops right into the heart of the swarm.."/>

	<entry name="AstraMilitarum/AdditionalHeavyBolters" value="Additional heavy weapons"/>
	<entry name="AstraMilitarum/AdditionalHeavyBoltersDescription" value="Allows additional Heavy Bolters to be mounted on the Baneblade, Devil Hound, Rogal Dorn battle tank, Valkyrie, gives Basilisks the ability to reduce armor and increases the damage of the Victorious Cannon on the Leman Russ tank."/>
	<entry name="AstraMilitarum/AdditionalHeavyBoltersFlavor" value="&lt;string name='Weapons/HeavyBolterFlavor'/&gt;"/>

	<entry name="AstraMilitarum/SastraMilitaries" value="Military forces of Militarum"/>
    <entry name="AstraMilitarum/SastraMilitariesDescription" value="Gives Astra Militarum infantry bonuses that make them stronger in combat. Guardsmen have 100% second-range attacks, separate heavy weapons do not lose accuracy after moving, Tempestus ability +1 attack range, Ratlings +1 max movement, Bykryns reduce max movement with attack, Psykers +1 ability duration."/>

	<entry name="SpaceMarines/PredatorLascannon" value="Additional weapons"/>
	<entry name="SpaceMarines/PredatorLascannonDescription" value="Gives Predators an additional twin-linked lascannon, but increases upkeep by 1. Grants Redemption Fortresses and Aquila Megacannons additional heavy bolters."/>
	<entry name="SpaceMarines/PredatorLascannonFlavor" value="&lt;string name='Weapons/HeavyBolterFlavor'/&gt;"/>

	<entry name="AstraMilitarum/Baneblade" value="<string name='Units/AstraMilitarum/Shadowsword'/>"/>
	<entry name="AstraMilitarum/BanebladeDescription" value="<string name='Units/AstraMilitarum/ShadowswordDescription'/>"/>
	<entry name="AstraMilitarum/BanebladeFlavor" value="<string name='Units/AstraMilitarum/ShadowswordFlavor'/>"/>

	<entry name="AstraMilitarum/DisciplineMove" value="Discipline above all else"/>
	<entry name="AstraMilitarum/DisciplineMoveDescription" value="All officers gain +1 to the radius of the Discipline aura. All infantry within the aura's radius do not suffer a penalty to movement in forests, ruins, and rivers. Heavy weapons units gain an ability that increases damage to air targets."/>
	<entry name="AstraMilitarum/DisciplineMoveFlavor" value="Every soldier who lost faith in the Emperor lost himself."/>

	<entry name="AstraMilitarum/MixCover" value="Shelter from fire"/>
	<entry name="AstraMilitarum/MixCoverDescription" value="Infantry begins to take cover from fire behind allied Astra Militarum vehicles, receiving 33% ranged damage reduction."/>

	<entry name="AstraMilitarum/PsykersPower" value="Witchcraft"/>
	<entry name="AstraMilitarum/PsykersPowerDescription" value="Psykers gain the ability to use their abilities without spending actions."/>

	<entry name="SpaceMarines/BolterDiscipline" value="Bolter Discipline"/>
	<entry name="SpaceMarines/BolterDisciplineDescription" value="Gives the Tactical a new trait - if the unit remains stationary, they fire Rapid Fire weapons with increased attacks at all ranges."/>
	<entry name="SpaceMarines/BolterDisciplineFlavor" value="To a Space Marine, the boltgun is more than a weapon—it is an instrument of Mankind’s divinity, the bringer of death to his foes."/>

	<entry name="SpaceMarines/MultiChapter" value="&lt;string name='Traits/SpaceMarines/MultiChapter'/&gt;"/>
	<entry name="SpaceMarines/MultiChapterDescription" value="Allows basic Space Marine units to benefit from the abilities and doctrines of different Chapters, and provides a marker that increases the damage of Chapter units to a target."/>
	<entry name="SpaceMarines/MultiChapterFlavor" value="&lt;string name='Traits/SpaceMarines/MultiChapterFlavor'/&gt;"/>

	<entry name="SpaceMarines/IronHands1" value="Iron Hands Scout Biker"/>
	<entry name="SpaceMarines/IronHands1Description" value="Mobile reconnaissance unit of the Chapter of the Iron Hands."/>
	<entry name="SpaceMarines/IronHands1Flavor" value="&lt;string name='Units/SpaceMarines/ScoutBikerFlavor'/&gt;"/>

	<entry name="SpaceMarines/OrbitalUpgrade" value="Advanced Scanning"/>
	<entry name="SpaceMarines/OrbitalUpgradeDescription" value="Reduces reload time and increases scanning radius."/>
	<entry name="SpaceMarines/OrbitalUpgradeFlavor" value="&lt;string name='Actions/OrbitalScanFlavor'/&gt;"/>

	<entry name="SpaceMarines/AdvancedPool" value="Fermentation Gathering"/>
	<entry name="SpaceMarines/AdvancedPoolDescription" value="Increases resources collected from the 'Fermentation Pool' terrain feature."/>
	<entry name="SpaceMarines/AdvancedPoolFlavor" value="&lt;string name='Features/FermentationPoolFlavor'/&gt;"/>

	<entry name="SpaceMarines/FortressSupreme" value="Supreme Fortress"/>
	<entry name="SpaceMarines/FortressSupremeDescription" value="Allows you to mount additional Bolters and a Lascannon on your Space Marine HQ, and restores health to your HQ and Redemption Fortresses every turn.."/>
	<entry name="SpaceMarines/FortressSupremeFlavor" value="Each Chapter of the Adeptus Astartes contains a mighty fortress-monastery, a sanctuary where new generations of Space Marines are trained and where the Chapter's secrets are kept."/>

	<entry name="SpaceMarines/NoFear" value="Fearless"/>
	<entry name="SpaceMarines/NoFearDescription" value="Reduces morale loss and grants immunity to fear and pinning for Space Marine infantry units."/>
	<entry name="SpaceMarines/NoFearFlavor" value="&lt;string name='Traits/AndTheyShallKnowNoFear'/&gt;"/>

	<entry name="SpaceMarines/ChapterMasters" value="Chapter Masters"/>
	<entry name="SpaceMarines/ChapterMastersDescription" value="Adds new abilities to heroes. Librarian gains the ability to 'Levitate', Captain - 'Captain's Armor' (Reduces ranged attacks of adjacent units), Chaplain - 'Aura of Fortitude' (Increases ranged damage reduction and cannot be targeted by attacks from overwatch), and allows heroes to receive bonuses from doctrines of different Orders."/>
	<entry name="SpaceMarines/ChapterMastersFlavor" value="'They will become my best warriors, completely devoted to me, as if I were molding them from clay and burning them in the crucible of war.'"/>

    <entry name="SpaceMarines/LandSpeederDescription" value="Unlocks the RavenGuard Doctrine and a mobile hover vehicle that can even travel on water."/>
    <entry name="SpaceMarines/PrimarisInvaderATVDescription" value="Unlocks the Black Templars Doctrine and a fast vehicle armed with a gatling gun."/>
    <entry name="SpaceMarines/ThunderfireCannonDescription" value="Unlocks the Iron Hands Doctrine and a cannon that provides long-range fire support."/>
    <entry name="SpaceMarines/WhirlwindDescription" value="Unlocks the Salamanders Doctrine and an artillery tank with an arsenal of missiles to pound enemy positions from a long distance."/>
    <entry name="SpaceMarines/PrimarisAggressorDescription" value="Unlocks the Imperial Fists Doctrine and a close combat anti-infantry unit armed with Flamestorm Gauntlets."/>
    <entry name="SpaceMarines/ApothecaryDescription" value="Upgrades Doctrine and unlocks an infantry unit that heals allied infantry."/>
    <entry name="SpaceMarines/DreadnoughtDescription" value="Upgrades Doctrine and unlocks a heavy walker that crushes foes."/>
    <entry name="SpaceMarines/PredatorDescription" value="Upgrades Doctrine and unlocks an Astartes main battle tank."/>
    <entry name="SpaceMarines/PrimarisInceptorDescription" value="Upgrades Doctrine and unlocks a powerful close combat unit equipped with jump packs."/>
    <entry name="SpaceMarines/StormSpeederThunderstrikeDescription" value="Upgrades Doctrine and unlocks a fast assault vehicle with powerful anti-tank weapons."/>
    <entry name="SpaceMarines/PrimarisHellblasterDescription" value="Upgrades the Chapter trait and unlocks heavy armor-piercing rifle infantry."/>
    <entry name="SpaceMarines/DevastatorSpaceMarineDescription" value="Upgrades the Chapter trait and unlocks infantry armed to combat heavy combat vehicles."/>
    <entry name="SpaceMarines/AssaultTerminatorDescription" value="Upgrades the Chapter trait and unlocks heavy melee infantry with powerful weapons and shields."/>
    <entry name="SpaceMarines/RedemptorDreadnoughtDescription" value="Upgrades the Chapter trait and unlocks a powerful walker with a wide arsenal of weapons."/>
    <entry name="SpaceMarines/StormravenGunshipDescription" value="Upgrades the Chapter's trait and unlocks heavily armed and armored air transports."/>

    <entry name="SpaceMarines/LowTierScale" value="Legion Reinforcements"/>
    <entry name="SpaceMarines/LowTierScaleDescription" value="Adds +3 max health to Scout Motor Squad and Bolter Discipline, +1 attack range to Hunters, Shield to Space Marine Assault Squads, Signum ability for Scouts, adds a Storm Bolter to Cleaver, a shield to Tactical Squads, and Intercessors gain a new 'Forge Flame' trait that deals damage over time and blocks all healing."/>
    <entry name="SpaceMarines/LowTierScaleFlavor" value="Almost every Space Marine created since the First Founding has nineteen specialized implants, but their Primaris brethren have three more unique organs."/>

    <entry name="SpaceMarines/LowTierScale2" value="Frame of Loyalty"/>
    <entry name="SpaceMarines/LowTierScale2Description" value="Adds additional heavy weapons to the Predator and Landspeeder, a new 'Thunderbolt' ability to the Dreadnought, a 'Pointer' ability to the Whirlwind, increases the max health of Apothecaries, and makes Intercessors cheaper."/>
    <entry name="SpaceMarines/LowTierScale2Flavor" value="Almost every Space Marine created since the First Founding has nineteen specialized implants, but their Primaris brethren have three more unique organs."/>

    <entry name="SpaceMarines/ChapterAssign" value="Organized Armies"/>
    <entry name="SpaceMarines/ChapterAssignDescription" value="Space Marine Chapter units gain a new trait that increases damage to targets attacked by other Chapters."/>
    <entry name="SpaceMarines/ChapterAssignFlavor" value="Originally, Chapters were the organizational unit of the Thunder Warriors army. During the Great Crusade, the Space Marines were divided into Legions, which in turn were made up of Companies."/>

    <entry name="SpaceMarines/FlyerSight" value="Astartes X-Ray"/>
    <entry name="SpaceMarines/FlyerSightDescription" value="Increases the sight radius of Space Marine Flyers and Skimmers, and prevents Flyers from being targeted by enemy overwatch attacks."/>
    <entry name="SpaceMarines/FlyerSightFlavor" value="&lt;string name='Traits/SpaceMarines/FlyerSightFlavor'/&gt;"/>

    <entry name="SpaceMarines/NoLosses" value="No Losses"/>
    <entry name="SpaceMarines/NoLossesDescription" value="Reduces morale loss for infantry units and they gain a new ability that reduces morale loss for allies."/>
    <entry name="SpaceMarines/NoLossesFlavor" value="In a galaxy shrouded in darkness, we must become the light. In times when the tides of despair rise high, we must rise higher. In an age when reason and hope flee, we must stand to the death."/>

	<entry name="SpaceMarines/TacticalSolution" value="Tactical Decisions"/>
	<entry name="SpaceMarines/TacticalSolutionDescription" value="Reduces cooldown for Scan, Fortress of Redemption, and Orbital Bombardment."/>
    <entry name="SpaceMarines/TacticalSolutionFlavor" value="Chapters are monastic in nature, with most Space Marines' Chapters being limited to their entire world, and only interacting with outsiders in battle."/>

	<entry name="SpaceMarines/DoctrineMasters" value="Emperor's Order"/>
	<entry name="SpaceMarines/DoctrineMastersDescription" value="Reduces cooldown for doctrines of all Orders."/>

