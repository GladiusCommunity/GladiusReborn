	<entry name="AstraMilitarum/Kasrkin" value="Kasrkin"/>
	<entry name="AstraMilitarum/KasrkinDescription" value="Elite infantry unit of the Astra Militarum."/>
	<entry name="AstraMilitarum/KasrkinFlavor" value="When veteran Guardsmen flee, the Kasrkin stand. When victory is near, the Kasrkin seize it. When the Archenemy attacks, the Kasrkin Elite are the rock upon which traitors shall break."/>
	
