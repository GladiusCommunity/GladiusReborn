    <entry name="AstraMilitarumAircraftProductionEdict" value="Energy Order"/>
    <entry name="AstraMilitarumAircraftProductionEdictDescription" value="Edicts increasing Voidport city output and energy production."/>
    <entry name="AstraMilitarumAircraftProductionEdictFlavor" value="Edict, Departmento Munitorum: To all Voidport Masters. Workers' sleep cycles are halved until further notice, and production targets are increased. Arbitrators have been dispatched to all sectors to ensure compliance."/>


