	<entry name="SpaceMarines/DefenseShroud" value="Mass Veil!"/>
	<entry name="SpaceMarines/DefenseShroudDescription" value="Creates a smoke screen on Stormraven's tile and adjacent tiles that provides ranged damage reduction."/>

	<entry name="SpaceMarines/DevastatorBypass" value="Reset"/>
	<entry name="SpaceMarines/DevastatorBypassDescription" value="Removes all invulnerability effects from the target."/>
	<entry name="SpaceMarines/DevastatorBypassFlavor" value="Devastator Centurions are used in missions that require Space Marines to have exceptional firepower, comparable to tanks, in areas where tanks are otherwise unavailable."/>

	<entry name="SpaceMarines/BlindShot" value="Ослепляющая Граната"/>
	<entry name="SpaceMarines/BlindShotDescription" value="Reduces the accuracy of the target enemy infantry or monstrous creature unit."/>
	<entry name="SpaceMarines/BlindShotFlavor" value="Blind grenades are a more complex version of a smoke grenade, releasing a dense dark grey smoke cloud, as well as infrared bafflers, broad spectrum electromagnetic radiation and chaff to disrupt enemy scanners. The broad range of interference makes most forms of direct attack through it impossible for a short time."/>

	<entry name="SpaceMarines/LandCruiser" value="Warp Immunity"/>
	<entry name="SpaceMarines/LandCruiserDescription" value="Increases damage reduction from witchfire to adjacent allied Order units."/>
	<entry name="SpaceMarines/LandCruiserFlavor" value="The energy field creates a zone cut off from the forces generated by the Warp."/>

	<entry name="SpaceMarines/ArmourContempt" value="Armour of Contempt"/>
	<entry name="SpaceMarines/ArmourContemptDescription" value="Grants damage reduction to adjacent allied Order infantry units with pain immunity."/>
	<entry name="SpaceMarines/ArmourContemptFlavor" value="Apothecaries are held in high regard by their brethren, as they are charged with the task of guarding the purity of the gene-seed: if a Chapter's genetic material mutates, it could lead to the Chapter's extinction, or worse, to a defection to Chaos."/>

	<entry name="SpaceMarines/SalamandersDoctrine" value="The Salamanders Doctrine"/>
	<entry name="SpaceMarines/SalamandersDoctrineDescription" value="An Order tactic that provides damage reduction from ranged fire at first range."/>
	<entry name="SpaceMarines/SalamandersDoctrineFlavor" value="&lt;string name='Traits/SpaceMarines/SalamandersFlavor'/&gt;"/>

	<entry name="SpaceMarines/SalamandersPresence" value="Self-sacrifice"/>
	<entry name="SpaceMarines/SalamandersPresenceDescription" value="Reduces the accuracy of range fire for adjacent enemy units."/>
	<entry name="SpaceMarines/SalamandersPresenceFlavor" value="The Salamanders' beliefs are based on the ancient cult of Prometheus, which preaches independence, devotion and self-sacrifice."/>

	<entry name="SpaceMarines/HonorForge" value="Burning power"/>
	<entry name="SpaceMarines/HonorForgeDescription" value="Sacrifices Health Points to increase damage and armor penetration."/>
	<entry name="SpaceMarines/HonorForgeFlavor" value="The main symbols of the Prometheus cult are the hammer and the flame. Salamander battle-brothers often bear ritual marks and scars made with fire."/>

	<entry name="SpaceMarines/RavenguardDoctrine" value="The RavenGuard Doctrine"/>
	<entry name="SpaceMarines/RavenguardDoctrineDescription" value="An Order tactic that grants movement points after kills."/>
	<entry name="SpaceMarines/RavenguardDoctrineFlavor" value="&lt;string name='Traits/SpaceMarines/RavenGuardFlavor'/&gt;"/>

	<entry name="SpaceMarines/ImperialDoctrine" value="The Imperial Fists Doctrine"/>
	<entry name="SpaceMarines/ImperialDoctrineDescription" value="An Order tactic that increases damage dealt to vehicles and fortifications, and provides a permanent damage reduction to allied Order infantry."/>
	<entry name="SpaceMarines/ImperialDoctrineFlavor" value="&lt;string name='Traits/SpaceMarines/ImperialFistsFlavor'/&gt;"/>

	<entry name="SpaceMarines/RangeReduction" value="Outflank"/>
	<entry name="SpaceMarines/RangeReductionDescription" value="&lt;string name='Actions/SpaceMarines/OmniscopeDescription'/&gt;"/>
	<entry name="SpaceMarines/RangeReductionFlavor" value="When the darkness closes in and the claws of the unknown close around the throat of your army, I need no other warriors at my side - for the Imperial Fists fight like the titans of legend!»"/>

	<entry name="SpaceMarines/IronDoctrine" value="The Iron Hands Doctrine"/>
	<entry name="SpaceMarines/IronDoctrineDescription" value="The Order's tactics, under which the Order's units restore health points and instead of penalties from missing health points and lost morale - on the contrary, they receive bonuses proportional to the penalties (for 33% and 66% of health and morale losses)."/>
	<entry name="SpaceMarines/IronDoctrineFlavor" value="&lt;string name='Traits/SpaceMarines/IronHandsFlavor'/&gt;"/>

	<entry name="SpaceMarines/TemplarsDoctrine" value="The Black Templars Doctrine"/>
	<entry name="SpaceMarines/TemplarsDoctrineDescription" value="An Order Tactic that increases damage and damage reduction with Pain Insensitivity for each enemy Psyker standing in range."/>
	<entry name="SpaceMarines/TemplarsDoctrineFlavor" value="&lt;string name='Traits/SpaceMarines/BlackTemplarsFlavor'/&gt;"/>

    <entry name="SpaceMarines/SummonHonourGuard" value="Summon Honour Guard"/>
    <entry name="SpaceMarines/SummonHonourGuardDescription" value="Temporary summons Honour Guard unit, elite cadre of Veteran Space Marines."/>

	<entry name="SpaceMarines/GoingThrough" value="Movement through"/>
	<entry name="SpaceMarines/GoingThroughDescription" value="Allows an allied Space Marine unit to ignore enemy Zone of Control, ignore movement penalties on rivers, forests, ruins and increases max movement."/>
	<entry name="SpaceMarines/GoingThroughFlavor" value="Rejoice! Let the joy of battle fill us! Let our enemies fear us, for we are the Emperor's wrath!"/>

	<entry name="SpaceMarines/PulseShielding" value="&lt;string name='Traits/SpaceMarines/PulseShielding'/&gt;"/>
	<entry name="SpaceMarines/PulseShieldingDescription" value="Gives allied Space Marine vehicles a protective field that completely protects against damage from a single attack, does not work on overwatch attacks."/>
	<entry name="SpaceMarines/PulseShieldingFlavor" value="&lt;string name='Traits/SpaceMarines/PulseDefenseFlavor'/&gt;"/>

	<entry name="SpaceMarines/AccuracyFuse" value="True Strike"/>
	<entry name="SpaceMarines/AccuracyFuseDescription" value="Limits accuracy loss for allied Space Marine vehicles."/>
	<entry name="SpaceMarines/AccuracyFuseFlavor" value="You will be asked if you had the right to destroy tens of billions. But only a few will understand that you simply had no right to leave them alive."/>

	<entry name="SpaceMarines/VeilOfTime" value="Veil Of Time"/>
    <entry name="SpaceMarines/VeilOfTimeDescription" value="Increases the research and influence output of the empire."/>
    <entry name="SpaceMarines/VeilOfTimeFlavor" value="The psyker projects his will beyond the regular passage of time, altering the temporal flow to sway the tide of battle."/>

	<entry name="SpaceMarines/SpectralBlade" value="<string name='Traits/SpaceMarines/SpectralBlade'/>"/>
    <entry name="SpaceMarines/SpectralBladeDescription" value="<string name='Traits/SpaceMarines/SpectralBladeDescription'/>"/>
    <entry name="SpaceMarines/SpectralBladeFlavor" value="<string name='Traits/SpaceMarines/SpectralBladeFlavor'/>"/>

	<entry name="SpaceMarines/MightOfHeroes" value="<string name='Traits/SpaceMarines/MightOfHeroes'/>"/>
    <entry name="SpaceMarines/MightOfHeroesDescription" value="<string name='Traits/SpaceMarines/MightOfHeroesDescription'/>"/>
    <entry name="SpaceMarines/MightOfHeroesFlavor" value="<string name='Traits/SpaceMarines/MightOfHeroesFlavor'/>"/>

    <entry name="SpaceMarines/NullZone" value="<string name='Traits/NullZone'/>"/>
    <entry name="SpaceMarines/NullZoneDescription" value="Removes invulnerable, witchfire and feel no pain damage reduction on non-hero units adjacent to Librarian."/>
    <entry name="SpaceMarines/NullZoneFlavor" value="<string name='Traits/NullZoneFlavor'/>"/>

	<entry name="SpaceMarines/HeroicStand" value="Aura of Fortitude"/>
    <entry name="SpaceMarines/HeroicStandDescription" value="Increases ranged damage reduction against attacks from 2 or more ranges. Also, the Chaplain cannot be targeted by attacks from overwatch."/>
    <entry name="SpaceMarines/HeroicStandFlavor" value="<string name='Traits/SpaceMarines/HeroicStandFlavor'/>"/>

    <entry name="HealingSurgeDescription" value="Restores Health Points to the Captain and adjacent Space Marine infantry units."/>

	<entry name="SpaceMarines/CaptainBlock" value="Captain's Armor"/>
	<entry name="SpaceMarines/CaptainBlockDescription" value="Reduces ranged attacks of adjacent enemy units."/>
    <entry name="SpaceMarines/CaptainBlockFlavor" value="The Captain commands from the front lines. By example, he shows his men what it means to be an Adeptus Astartes, and under his leadership, his brothers learn the cost of fighting in the Emperor's name."/>

	<entry name="SpaceMarines/TacticalShielding" value="&lt;string name='Traits/SpaceMarines/TacticalShielding'/&gt;"/>
	<entry name="SpaceMarines/TacticalShieldingDescription" value="Tactical shield, which protects against damage from one attack, does not work on attacks from overwatch."/>
	<entry name="SpaceMarines/TacticalShieldingFlavor" value="&lt;string name='Traits/SpaceMarines/TacticalShieldingFlavor'/&gt;"/>

	<entry name="SpaceMarines/DreadForge" value="&lt;string name='Traits/SpaceMarines/DreadForge'/&gt;"/>
	<entry name="SpaceMarines/DreadForgeDescription" value="Sacrifices Health Points to increase damage and armor penetration."/>
	<entry name="SpaceMarines/DreadForgeFlavor" value="&lt;string name='Traits/SpaceMarines/DreadForgeFlavor'/&gt;"/>

	<entry name="SpaceMarines/RapidWind" value="Pointer"/>
    <entry name="SpaceMarines/RapidWindDescription" value="Increases the range of the Rapid Fire trait."/>
    <entry name="SpaceMarines/RapidWindFlavor" value="The Whirlwind's artillery strikes are a source of terror for many opponents. History knows of many examples of Ork chieftains using large contingents of warriors just to locate and destroy Whirlwind batteries."/>

	<entry name="SpaceMarines/NoLossesAura" value="&lt;string name='Upgrades/SpaceMarines/NoLosses'/&gt;"/>
	<entry name="SpaceMarines/NoLossesAuraDescription" value="&lt;string name='Traits/SpaceMarines/NoLossesAuraDescription'/&gt;"/>
    <entry name="SpaceMarines/NoLossesAuraFlavor" value="&lt;string name='Upgrades/SpaceMarines/NoLossesFlavor'/&gt;"/>

    <entry name="SpaceMarines/MakeChampionBlackTemplar" value="Champion of the Black Templars"/>
    <entry name="SpaceMarines/MakeChampionBlackTemplarDescription" value="Summons the Black Templar Champion."/>
    <entry name="SpaceMarines/MakeChampionBlackTemplarFlavor" value="Many Chapters have had Space Marines who have held this title at various times, most notably the First and Second Founding Chapters, whose history dates back to the Horus Heresy and the Great Scouring."/>

    <entry name="SpaceMarines/ChampionBlackTemplar" value="Champion of the Black Templars"/>
    <entry name="SpaceMarines/ChampionBlackTemplarDescription" value="There can only be one Order Champion on the battlefield."/>
    <entry name="SpaceMarines/ChampionBlackTemplarFlavor" value="&lt;string name='Actions/SpaceMarines/MakeChampionBlackTemplarFlavor'/&gt;"/>

	<entry name="SpaceMarines/ChampionCrush" value="Reconing"/>
    <entry name="SpaceMarines/ChampionCrushDescription" value="Stuns the selected enemy unit."/>

	<entry name="SpaceMarines/ChampionAccuracy" value="Victory Drive"/>
    <entry name="SpaceMarines/ChampionAccuracyDescription" value="Increases the accuracy of allied Chapter units and reduces the accuracy of enemy units."/>
    <entry name="SpaceMarines/ChampionAccuracyFlavor" value="Known for their pride, coolness and ruthlessness in battle, the Iron Hands were one of the most renowned and feared Legions during the Great Crusade. They were the hammer that crushed countless foes in the name of the Emperor."/>

	<entry name="SpaceMarines/ExploitWeaknesses" value="Breach in Defense"/>
    <entry name="SpaceMarines/ExploitWeaknessesDescription" value="Reduces the armor of a targeted enemy unit."/>
    <entry name="SpaceMarines/ExploitWeaknessesFlavor" value="Some Astartes scoff at compassion, seeing it as just another human weakness that has been purged from their superior transhuman bodies and minds. But the wisest of Marines know that in the end, compassion is their only salvation."/>


</language>
