    <entry name="SpaceMarines/ShatterDefencesDescription"
           value="Removes the ranged damage reduction of the target tile."/>

	<entry name="AuraOfDiscipline" value="Aura of discipline"/>
	<entry name="AuraOfDisciplineDescription" value="Increases accuracy and provides additional bonuses to adjacent allied Astra Militarum infantry."/>

	<entry name="AstraMilitarum/MeatShield" value="Meat shield"/>
	<entry name="AstraMilitarum/MeatShieldDescription" value="Decreases the range attacks of adjacent enemy units."/>

	<entry name="AstraMilitarum/DogmaMilitarum" value="Militarum Force"/>
	<entry name="AstraMilitarum/DogmaMilitarumDescription" value="Increases loyalty in cities."/>

	<entry name="AstraMilitarum/SuperchargedLas" value="Supercharged Las"/>
    <entry name="AstraMilitarum/SuperchargedLasDescription" value="Increases the attacks of hot shot lasguns."/>

	<entry name="AstraMilitarum/Generalism" value="Aura of the General"/>
	<entry name="AstraMilitarum/GeneralismDescription" value="Increases accuracy and provides additional bonuses to adjacent allied Astra Militarum officers."/>

	<entry name="AstraMilitarumVehicleProductionEdict" value="Inspired Training"/>
	<entry name="AstraMilitarumVehicleProductionEdictDescription" value="Edict that increases the production output of Imperial Barracks and Manufactorums in the city."/>

	<entry name="AstraMilitarum/DeployVoidShieldGenerator" value="Install shield generator"/>
	<entry name="AstraMilitarum/DeployVoidShieldGeneratorDescription" value="&lt;string name='Traits/AstraMilitarum/VoidShieldDescription'/&gt;"/>

	<entry name="AstraMilitarum/KillOnSight" value="“Kill On Sight!”"/>
	<entry name="AstraMilitarum/KillOnSightDescription" value="Increases ranged attacks of adjacent allied tanks."/>
	<entry name="AstraMilitarum/KillOnSightFlavor" value="The officer gives his men complete freedom of action to begin rapid fire on targets."/>

	<entry name="AstraMilitarum/MoveThrough" value="“Straight ahead!”"/>
	<entry name="AstraMilitarum/MoveThroughDescription" value="Adds maximum movement to adjacent allied tanks."/>
	<entry name="AstraMilitarum/MoveThroughFlavor" value="The officer leads a glorious detachment of tanks that grinds the enemy with their tracks."/>

	<entry name="SummaryExecution" value="Execution"/>
	<entry name="SummaryExecutionDescription" value="Restores morale to friendly units and reduces morale loss in battle."/>
	<entry name="SummaryExecutionFlavor" value="At the very least, a Commissar must be prepared to execute cowardly soldiers or incompetent officers without remorse; few things in the world can enforce discipline as effectively. Better than discontent or cowardice is a bullet to the forehead, and that message to others is even stronger when a bolt's reactive shell disintegrates a Guardsman's brains in front of his horrified comrades."/>

	<entry name="AstraMilitarum/MixCover" value="Shelter from fire"/>
	<entry name="AstraMilitarum/MixCoverDescription" value="Infantry begins to take cover from fire behind allied Astra Militarum vehicles, receiving 33% ranged damage reduction."/>

	<entry name="AstraMilitarum/Unwavering" value="Immortal Guard"/>
	<entry name="AstraMilitarum/UnwaveringDescription" value="Increases damage reduction and restores health to the Primaris Psyker and adjacent allied Astra Militarum infantry."/>

	<entry name="AstraMilitarum/MentalShackles" value="Mental Shackles"/>
    <entry name="AstraMilitarum/MentalShacklesDescription" value="Stuns target enemy unit."/>

	<entry name="AstraMilitarum/MasterTactician" value="Master Tactician"/>
    <entry name="AstraMilitarum/MasterTacticianDescription" value="Increases the max movement of the selected allied AM vehicle and gives it additional attacks."/>

	<entry name="AstraMilitarumDefenseEdict" value="Bulwark of the Emperor"/>
	<entry name="AstraMilitarumDefenseEdictDescription" value="An edict that increases the armor of allied Astra Militarum infantry."/>

	<entry name="Necrons/Wraithflight" value="Wraith flight"/>
    <entry name="Necrons/WraithflightDescription" value="Allows to move through enemy units and increase max movement."/>

	<entry name="AstraMilitarum/TankDam" value="Battle tank"/>
	<entry name="AstraMilitarum/TankDamDescription" value="Increases attacks by 33%."/>

	<entry name="AstraMilitarum/TankSup" value="Support tank"/>
	<entry name="AstraMilitarum/TankSupDescription" value="Reduces ability cooldown by 1 turn and gains the ability to reduce armor with attack."/>

	<entry name="AstraMilitarum/Attacking" value="Equipment setup"/>
	<entry name="AstraMilitarum/AttackingDescription" value="Increases the accuracy of ranged attacks."/>

    <entry name="AstraMilitarum/AttilanControlZone" value="Breakthrough!"/>
    <entry name="AstraMilitarum/AttilanControlZoneDescription" value="Increases irreducible damage reduction and allows you to ignore enemy Zone of Control."/>
    <entry name="AstraMilitarum/AttilanControlZoneFlavor" value="Shock cavalry that charge into battle despite the roar of autocannons and the flash of lascannon fire. These brave warriors ride into battle atop their mounts, slashing at the enemy with deadly melta-tipped spears."/>

	<entry name="Misfortune" value="Speech of the Warp"/>
	<entry name="MisfortuneDescription" value="Reduces attack and max movement of the target enemy unit."/>

		<entry name="SpaceMarines/RangeDeflecting" value="Defense of the Order"/>
	<entry name="SpaceMarines/RangeDeflectingDescription" value="Reduces ranged attacks of adjacent enemy units and reduces movement of nearby enemy monstrous creatures."/>

	<entry name="SpaceMarines/BlackTemplarsMove" value="Zeal"/>
	<entry name="SpaceMarines/BlackTemplarsMoveDescription" value="Increases movement."/>

	<entry name="SpaceMarines/DefensiveFocus" value="Defensive Stand"/>
    <entry name="SpaceMarines/DefensiveFocusDescription" value="Increases count of overwatch attacks but deals no damage when shooting this turn."/>
    <entry name="SpaceMarines/DefensiveFocus" value="As the Codex Astartes dictates, when the foe presses hard at one section of the Ultramarines’ battle line they are swift to concentrate their defensive fire to drive the threat back."/>

	<entry name="SpaceMarines/TemplarPresence" value="The Presence of the Black Templars"/>
	<entry name="SpaceMarines/TemplarPresenceDescription" value="Prevents adjacent enemy units from attacking from overwatch."/>
	<entry name="SpaceMarines/TemplarPresenceFlavor" value="The mere sight of the elite Astartes vehicles terrifies the enemy."/>

	<entry name="SpaceMarines/PowerClaw" value="Power Grip"/>
	<entry name="SpaceMarines/PowerClawDescription" value="Immobilizes enemy ground vehicles."/>

	<entry name="SpaceMarines/BornInFire" value="Born in Fire"/>
	<entry name="SpaceMarines/BornInFireDescription" value="Increases damage reduction."/>
		<entry name="SpaceMarines/BornInFireFlavor" value="If you are unable to withstand the damage that the enemy can inflict on you, the time will come when you will be defeated, and in your defeat you will render useless the sacrifice of millions."/>

