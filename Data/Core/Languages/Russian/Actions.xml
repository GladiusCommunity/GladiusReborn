	<entry name="SpaceMarines/ThunderfireAuraDescription" value="&lt;string name='Traits/SpaceMarines/ThunderfireAuraDescription'/&gt;"/>
	<entry name="SpaceMarines/ThunderfireAuraFlavor" value="&lt;string name='Traits/SpaceMarines/ThunderfireAuraFlavor'/&gt;"/>

	<entry name="SpaceMarines/PulseDefense" value="&lt;string name='Traits/SpaceMarines/PulseDefense'/&gt;"/>
	<entry name="SpaceMarines/PulseDefenseDescription" value="&lt;string name='Traits/SpaceMarines/PulseDefenseDescription'/&gt;"/>
	<entry name="SpaceMarines/PulseDefenseFlavor" value="&lt;string name='Traits/SpaceMarines/PulseDefenseFlavor'/&gt;"/>

	<entry name="SpaceMarines/MoraleFisting" value="&lt;string name='Traits/SpaceMarines/MoraleFisting'/&gt;"/>
	<entry name="SpaceMarines/MoraleFistingDescription" value="&lt;string name='Traits/SpaceMarines/MoraleFistingDescription'/&gt;"/>
	<entry name="SpaceMarines/MoraleFistingFlavor" value="&lt;string name='Traits/SpaceMarines/MoraleFistingFlavor'/&gt;"/>

	<entry name="SpaceMarines/ShieldUp" value="&lt;string name='Traits/SpaceMarines/ShieldUp'/&gt;"/>
	<entry name="SpaceMarines/ShieldUpDescription" value="Увеличивает броню смежным подразделениям Ордена Космического Десанта и снижает макс. движение. Действует на юнитов, которые не двигались на этот ход."/>
	<entry name="SpaceMarines/ShieldUpFlavor" value="&lt;string name='Traits/SpaceMarines/ShieldUpFlavor'/&gt;"/>

	<entry name="SpaceMarines/BlindGrenade" value="&lt;string name='Items/BlindGrenade'/&gt;"/>
	<entry name="SpaceMarines/BlindGrenadeDescription" value="&lt;string name='Items/BlinBlindGrenadeDescriptiondGrenade'/&gt;"/>
	<entry name="SpaceMarines/BlindGrenadeFlavor" value="&lt;string name='Items/BlindGrenadeFlavor'/&gt;"/>

	<entry name="SpaceMarines/DefenseShroud" value="Массовая Завеса!"/>
	<entry name="SpaceMarines/DefenseShroudDescription" value="Создаёт на плитке Грозового Ворона и смежных с ним плитках дымовую завесу, которая предоставляет сокращение дистанц. урона."/>

	<entry name="SpaceMarines/DevastatorBypass" value="Обнуление"/>
	<entry name="SpaceMarines/DevastatorBypassDescription" value="Снимает все эффекты неуязвимости с цели."/>
	<entry name="SpaceMarines/DevastatorBypassFlavor" value="Центурионы-опустошители занимаются заданиями, для которых космическому десанту требуется исключительная огневая мощь, сравнимая с танковой на местности, где танки по какой-либо причине недоступны."/>

	<entry name="SpaceMarines/BlindShot" value="Ослепляющая Граната"/>
	<entry name="SpaceMarines/BlindShotDescription" value="Снимает точность огня выбранной пехоты противника или монструозного создания."/>
	<entry name="SpaceMarines/BlindShotFlavor" value="Ослепляющая граната—более сложная версия дымовой гранаты, выпускает плотное темно-серое облако дыма, а также инфракрасные отражатели и электромагнитное излучение широкого спектра, чтобы вывести из строя вражеские сканеры. Широкий диапазон помех делает большинство видов прямой атаки через это облако невозможным на короткое время."/>

	<entry name="SpaceMarines/LandCruiser" value="Варп Иммунитет"/>
	<entry name="SpaceMarines/LandCruiserDescription" value="Повышает сокращение урона от колдовского огня смежным союзным подразделениям Ордена."/>
	<entry name="SpaceMarines/LandCruiserFlavor" value="Энергетическое поле создает зону, отрезанную от сил порожденных Варпом."/>

	<entry name="SpaceMarines/ArmourContempt" value="Доспехи Презрения"/>
	<entry name="SpaceMarines/ArmourContemptDescription" value="Даёт сокращение урона нечувствительностью к боли смежным союзным подразделениям пехоты Ордена."/>
	<entry name="SpaceMarines/ArmourContemptFlavor" value="Апотекарии пользуются большим уважением своих братьев, так как на них возложена задача охранять чистоту геносемени: если генный материал ордена мутирует, это может привести к вымиранию ордена или, того хуже, переходу на сторону Хаоса."/>

	<entry name="SpaceMarines/SalamandersDoctrine" value="Доктрина Саламандр"/>
	<entry name="SpaceMarines/SalamandersDoctrineDescription" value="Тактика Ордена, которая дает сокращение урона от дальнего огня с первой дистанции."/>
	<entry name="SpaceMarines/SalamandersDoctrineFlavor" value="&lt;string name='Traits/SpaceMarines/SalamandersFlavor'/&gt;"/>

	<entry name="SpaceMarines/SalamandersPresence" value="Самопожертвование"/>
	<entry name="SpaceMarines/SalamandersPresenceDescription" value="Снижает точность дальнего огня смежным отрядам противника."/>
	<entry name="SpaceMarines/SalamandersPresenceFlavor" value="В основе верований Саламандр лежит древний культ Прометея, который проповедует независимость, преданность и самопожертвование."/>

	<entry name="SpaceMarines/HonorForge" value="Обжигающая сила"/>
	<entry name="SpaceMarines/HonorForgeDescription" value="Жертвует Очками здоровья, чтобы увеличить наносимый урон и бронебойность."/>
	<entry name="SpaceMarines/HonorForgeFlavor" value="Основными символами культа Прометея являются молот и пламя. Боевые братья Саламандры часто носят ритуальные клейма и шрамы, нанесенные с помощью огня."/>

	<entry name="SpaceMarines/RavenguardDoctrine" value="Доктрина Гвардии Ворона"/>
	<entry name="SpaceMarines/RavenguardDoctrineDescription" value="Тактика Ордена, которая дает очки движения после убийств."/>
	<entry name="SpaceMarines/RavenguardDoctrineFlavor" value="&lt;string name='Traits/SpaceMarines/RavenGuardFlavor'/&gt;"/>

	<entry name="SpaceMarines/ImperialDoctrine" value="Доктрина Имперских Кулаков"/>
	<entry name="SpaceMarines/ImperialDoctrineDescription" value="Тактика Ордена, которая увеличивает наносимый урон по технике и фортификациям, а также дает неснижаемое сокращение урона союзной пехоте Ордена."/>
	<entry name="SpaceMarines/ImperialDoctrineFlavor" value="&lt;string name='Traits/SpaceMarines/ImperialFistsFlavor'/&gt;"/>

	<entry name="SpaceMarines/RangeReduction" value="Обход с фланга"/>
	<entry name="SpaceMarines/RangeReductionDescription" value="&lt;string name='Actions/SpaceMarines/OmniscopeDescription'/&gt;"/>
	<entry name="SpaceMarines/RangeReductionFlavor" value="Когда тьма окружает всё сильнее, а когти неизвестности сжимаются вокруг горла твоей армии, мне не нужны никакие другие воины рядом — потому что Имперские Кулаки сражаются, как титаны из легенд!»"/>

	<entry name="SpaceMarines/IronDoctrine" value="Доктрина Железных Рук"/>
	<entry name="SpaceMarines/IronDoctrineDescription" value="Тактика Ордена, под которой подразделения Ордена восстанавливают очки здоровья и вместо штрафов от недостающих очков здоровья и потерянной морали - наоборот получают бонусы пропорциональные штрафам(за 33% и 66% потерь здоровья и морали)."/>
	<entry name="SpaceMarines/IronDoctrineFlavor" value="&lt;string name='Traits/SpaceMarines/IronHandsFlavor'/&gt;"/>

	<entry name="SpaceMarines/TemplarsDoctrine" value="Доктрина Черных Храмовников"/>
	<entry name="SpaceMarines/TemplarsDoctrineDescription" value="Тактика Ордена, которая повышает урон и сокр. урона нечувствительностью к боли за каждого стоящего в радиусе вражеского Псайкера."/>
	<entry name="SpaceMarines/TemplarsDoctrineFlavor" value="&lt;string name='Traits/SpaceMarines/BlackTemplarsFlavor'/&gt;"/>

	<entry name="SpaceMarines/SummonHonourGuard" value="Призыв Почетной Гвардии"/>
    <entry name="SpaceMarines/SummonHonourGuardDescription" value="Временный призыв отряда Почетной Гвардии, элитного юнита-ветерана Космодесантников."/>

	<entry name="SpaceMarines/GoingThrough" value="Движение Сквозь"/>
	<entry name="SpaceMarines/GoingThroughDescription" value="Позволяет союзному юниту Космодесанта игнорировать вражескую зону контроля, игнорировать штрафы на передвижение по рекам, лесам, руинам и увеличивает макс. движение."/>
	<entry name="SpaceMarines/GoingThroughFlavor" value="Возрадуйтесь! Да наполнит нас радость битвы! Пусть страшатся нас враги наши, ибо мы — гнев Императора!"/>

	<entry name="SpaceMarines/PulseShielding" value="&lt;string name='Traits/SpaceMarines/PulseShielding'/&gt;"/>
	<entry name="SpaceMarines/PulseShieldingDescription" value="Дает союзной технике Космического Десанта защитное поле, полностью защищающее от урона одной атаки, не работает на атаки с дозора."/>
	<entry name="SpaceMarines/PulseShieldingFlavor" value="&lt;string name='Traits/SpaceMarines/PulseDefenseFlavor'/&gt;"/>

	<entry name="SpaceMarines/AccuracyFuse" value="Без Промаха"/>
	<entry name="SpaceMarines/AccuracyFuseDescription" value="Ограничивает потерю точности для союзной техники Космического Десанта."/>
	<entry name="SpaceMarines/AccuracyFuseFlavor" value="Тебя спросят, имел ли ты право уничтожить десятки миллиардов. Но лишь немногие поймут, что ты просто не имел права оставить их в живых."/>

	<entry name="SpaceMarines/VeilOfTime" value="Завеса Времени"/>
    <entry name="SpaceMarines/VeilOfTimeDescription" value="Увеличивает влияние и исследования."/>
    <entry name="SpaceMarines/VeilOfTimeFlavor" value="Псайкер проецирует свою волю за пределы обычного течения времени, изменяя временной поток, чтобы повлиять на ход битвы."/>

	<entry name="SpaceMarines/SpectralBlade" value="<string name='Traits/SpaceMarines/SpectralBlade'/>"/>
    <entry name="SpaceMarines/SpectralBladeDescription" value="<string name='Traits/SpaceMarines/SpectralBladeDescription'/>"/>
    <entry name="SpaceMarines/SpectralBladeFlavor" value="<string name='Traits/SpaceMarines/SpectralBladeFlavor'/>"/>

	<entry name="SpaceMarines/MightOfHeroes" value="<string name='Traits/SpaceMarines/MightOfHeroes'/>"/>
    <entry name="SpaceMarines/MightOfHeroesDescription" value="<string name='Traits/SpaceMarines/MightOfHeroesDescription'/>"/>
    <entry name="SpaceMarines/MightOfHeroesFlavor" value="<string name='Traits/SpaceMarines/MightOfHeroesFlavor'/>"/>

    <entry name="SpaceMarines/NullZone" value="<string name='Traits/NullZone'/>"/>
    <entry name="SpaceMarines/NullZoneDescription" value="Убирает cокращение урона от неуязвимости, колдовского огня и от нечувствительности к боли у отрядов, не являющихся героями, рядом с Библиарием."/>
    <entry name="SpaceMarines/NullZoneFlavor" value="<string name='Traits/NullZoneFlavor'/>"/>

	<entry name="SpaceMarines/HeroicStand" value="Аура Стойкости"/>
