    <entry name="SpaceMarines/DominusAegisDescription" value="<string name='Traits/SpaceMarines/DominusAegisDescription'/>"/>
    <entry name="SpaceMarines/DominusAegisFlavor" value="<string name='Traits/SpaceMarines/DominusAegisFlavor'/>"/>

	<entry name="LasCannonDoctrine" value="Энергетическая Доктрина"/>
	<entry name="LasCannonDoctrineDescription" value="Увеличивает точность сдвоенных энергетических орудий на 2."/>

	<entry name="SpaceMarines/ShatterDefences" value="Расколотая защита"/>
	<entry name="SpaceMarines/ShatterDefencesDescription" value="Снижает сокращение дистанц. урона до нуля на указанной плитке."/>

	<entry name="AuraOfDiscipline" value="Аура дисциплины"/>
	<entry name="AuraOfDisciplineDescription" value="Повышает точность и дает дополнительные бонусы смежной союзной пехоты Астра Милитарум."/>

	<entry name="AstraMilitarum/MeatShield" value="Мясной щит"/>
	<entry name="AstraMilitarum/MeatShieldDescription" value="Снижает дальние атаки смежным подразделениям врага."/>

	<entry name="AstraMilitarum/DogmaMilitarum" value="Сила Милитарум"/>
	<entry name="AstraMilitarum/DogmaMilitarumDescription" value="Увеличивает лояльность в городах."/>

	<entry name="AstraMilitarum/SuperchargedLas" value="Заряженный выстрел"/>
    <entry name="AstraMilitarum/SuperchargedLasDescription" value="Увеличивает атаки пробивного ружья."/>

	<entry name="AstraMilitarum/Generalism" value="Аура Генерала"/>
	<entry name="AstraMilitarum/GeneralismDescription" value="Повышает точность и дает дополнительные бонусы смежным союзным офицерам Астра Милитарум."/>

	<entry name="AstraMilitarumVehicleProductionEdict" value="Быстрое обучение"/>
	<entry name="AstraMilitarumVehicleProductionEdictDescription" value="Эдикт, увеличивающий выход продукции Мануфакторума и Имперских казарм в городе."/>

	<entry name="AstraMilitarum/DeployVoidShieldGenerator" value="Установить генератор щита"/>
	<entry name="AstraMilitarum/DeployVoidShieldGeneratorDescription" value="&lt;string name='Traits/AstraMilitarum/VoidShieldDescription'/&gt;"/>

	<entry name="AstraMilitarum/KillOnSight" value="“Убить!”"/>
	<entry name="AstraMilitarum/KillOnSightDescription" value="Повышает дистанционные атаки смежных союзных танков."/>
	<entry name="AstraMilitarum/KillOnSightFlavor" value="Офицер дает своим людям полную свободу действий, чтобы начать беглый огонь по целям."/>

	<entry name="AstraMilitarum/MoveThrough" value="“Напролом!”"/>
	<entry name="AstraMilitarum/MoveThroughDescription" value="Добавляет максимальное движение смежным союзным танкам."/>
	<entry name="AstraMilitarum/MoveThroughFlavor" value="Офицер ведет славный отряд танков, который перемалывает врага своими гусеницами."/>

	<entry name="SummaryExecution" value="Казнь"/>
	<entry name="SummaryExecutionDescription" value="Восстанавливает мораль дружественным подразделениям и снижает потерю морали в бою."/>
	<entry name="SummaryExecutionFlavor" value="В крайнем случае Комиссар должен быть готов к тому, чтобы казнить трусливых солдат или некомпетентных офицеров без угрызений совести; немногие вещи в мире также обеспечивают соблюдение дисциплины. Лучше, чем недовольство или трусость-пуля в лоб, и это послание другим становится еще сильнее, когда реактивная оболочка болта распыляет мозги Гвардейца перед лицом ужаснувшихся товарищей."/>

	<entry name="AstraMilitarum/MixCover" value="Укрытие от огня"/>
	<entry name="AstraMilitarum/MixCoverDescription" value="Пехота начинает укрываться от огня за союзной техникой Астра Милитарум, от чего получает 33% сокращения дистанционного урона."/>

	<entry name="AstraMilitarum/Unwavering" value="Бессмертная гвардия"/>
	<entry name="AstraMilitarum/UnwaveringDescription" value="Повышает сокращение урона и восстанавливает очки здоровья Примарису Псайкеру, а также смежной союзной пехоте Астра Милитарум."/>

	<entry name="AstraMilitarum/MentalShackles" value="Ментальные оковы"/>
    <entry name="AstraMilitarum/MentalShacklesDescription" value="Оглушает выбранный юнит противника."/>

	<entry name="AstraMilitarum/MasterTactician" value="Мастер тактики"/>
    <entry name="AstraMilitarum/MasterTacticianDescription" value="Увеличивает макс. движение выбранной союзной технике АМ и дает ей доп атаки."/>

	<entry name="AstraMilitarumDefenseEdict" value="Оплот Императора"/>
	<entry name="AstraMilitarumDefenseEdictDescription" value="Эдикт, который увеличивает броню союзной пехоте Астра Милитарум."/>

	<entry name="Necrons/Wraithflight" value="Полет Призрака"/>
    <entry name="Necrons/WraithflightDescription" value="Позволяет проходить сквозь отряды противника и увеличивает макс передвижение."/>

	<entry name="AstraMilitarum/TankDam" value="Боевой танк"/>
	<entry name="AstraMilitarum/TankDamDescription" value="Увеличивает атаки на 33%."/>

	<entry name="AstraMilitarum/TankSup" value="Танк поддержки"/>
	<entry name="AstraMilitarum/TankSupDescription" value="Cнижает перезарядку способностей на 1 ход и получает возможность снижать броню с атаки."/>

	<entry name="AstraMilitarum/Attacking" value="Наладка оборудования"/>
	<entry name="AstraMilitarum/AttackingDescription" value="Увеличивает точность дальних атак."/>

	<entry name="AstraMilitarum/AttilanControlZone" value="На Прорыв!"/>
	<entry name="AstraMilitarum/AttilanControlZoneDescription" value="Увеличивает неснижаемое сокращение урона и дает возможность игнорировать вражескую зону контроля."/>
	<entry name="AstraMilitarum/AttilanControlZoneFlavor" value="Ударная кавалерия, которая идёт в бой несмотря на грохот автопушек и вспышки выстрелов лазпушек. Храбрецы несутся в бой верхом на своих скакунах, поражая врага смертельно опасными копьями с мельта-наконечниками."/>

	<entry name="Misfortune" value="Язык Варпа"/>
	<entry name="MisfortuneDescription" value="Снижает атаки и макс. движение у выбранного вражеского юнита."/>

	<entry name="Enfeeble" value="Кара"/>
	<entry name="EnfeebleDescription" value="Наносит урон и накладывает разрушающий эффект на технику и монструозных существ противника."/>

	<entry name="SpaceMarines/RangeDeflecting" value="Защита Ордена"/>
	<entry name="SpaceMarines/RangeDeflectingDescription" value="Снижает дальние атаки смежным подразделениям врага и уменьшает движение рядом стоящим вражеским монструозным созданиям."/>

	<entry name="SpaceMarines/BlackTemplarsMove" value="Рвение"/>
	<entry name="SpaceMarines/BlackTemplarsMoveDescription" value="Увеличивает движение."/>

	<entry name="SpaceMarines/DefensiveFocus" value="Защитная Стойка"/>
    <entry name="SpaceMarines/DefensiveFocusDescription" value="Увеличивает количество атак с дозора, но не наносит урон при стрельбе в этом ходу."/>
    <entry name="SpaceMarines/DefensiveFocus" value="Как предписывает Кодекс Астартес, когда противник оказывает сильное давление на одного из участков боевой линии Ультрамаринов, они быстро концентрируют свой оборонительный огонь, чтобы отразить угрозу."/>

	<entry name="SpaceMarines/TemplarPresence" value="Присутствие Черных Храмовников"/>
	<entry name="SpaceMarines/TemplarPresenceDescription" value="Запрещает смежным вражеским отрядам атаковать из дозора."/>
	<entry name="SpaceMarines/TemplarPresenceFlavor" value="Один только вид элитной техники Астартес приводит в ужас врагов."/>

	<entry name="SpaceMarines/PowerClaw" value="Силовой хват"/>
	<entry name="SpaceMarines/PowerClawDescription" value="Обездвиживает наземную технику противника."/>

	<entry name="SpaceMarines/BornInFire" value="Рождённые в огне"/>
	<entry name="SpaceMarines/BornInFireDescription" value="Повышает сокращение урона."/>
	<entry name="SpaceMarines/BornInFireFlavor" value="Если вы не в силах выдержать тот урон, что способен нанести вам противник, наступит время, когда вы потерпите поражение, и в своём поражении сделаете бесполезной жертву миллионов."/>

	<entry name="SpaceMarines/SpaceMark" value="&lt;string name='Traits/SpaceMarines/SpaceMark'/&gt;"/>
	<entry name="SpaceMarines/SpaceMarkDescription" value="&lt;string name='Traits/SpaceMarines/SpaceMarkDescription'/&gt;"/>
	<entry name="SpaceMarines/SpaceMarkDefencesFlavor" value="&lt;string name='Traits/SpaceMarines/SpaceMarkFlavor'/&gt;"/>

