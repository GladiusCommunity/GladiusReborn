				<action sound="Actions/SmokeScreen"/>
			</model>
			<beginTargets>
				<selfTarget>
					<areas>
						<area affects="Tile">
							<modifiers>
								<modifier>
									<effects>
										<addFeature duration="1" name="SmokeScreen"/>
									</effects>
								</modifier>
							</modifiers>
						</area>
					</areas>
				</selfTarget>
			</beginTargets>
		</createSmokeScreen>
