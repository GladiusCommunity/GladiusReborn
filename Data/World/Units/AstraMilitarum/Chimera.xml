		<attack>
			<model>
				<action animation="Units/AstraMilitarum/ChimeraAttack"
						beginFire="0.77"
						endFire="2.6"/>
			</model>				
		</attack>
		<die>
			<model>
				<action animation="Units/AstraMilitarum/ChimeraDie0"
