		</weapon>
		<weapon name="HeavyBolter">
			<model>
				<projectileWeapon muzzleBone=".HeavyBolterMuzzle"/>
			</model>
		</weapon>
		<weapon name="LasgunArray" count="2">
			<model>
				<beamWeapon muzzleBone=".LasgunArrayMuzzle" muzzleCount="6"
