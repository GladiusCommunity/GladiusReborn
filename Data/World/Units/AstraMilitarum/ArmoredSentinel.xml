<?xml version="1.0" encoding="utf-8"?>
<unit>
	<model>
		<unit mesh="Units/AstraMilitarum/ScoutSentinel"
				material="Units/AstraMilitarum/ScoutSentinel"
				idleAnimation="Units/AstraMilitarum/ScoutSentinelIdle"
				idleAnimationCount="2"
				normalWeight="0.1"
				scale="1.0 1.0 1.0"
				syncMovementSounds="1"
				explosionsBone="HullBone"
				walker="1"/>
	</model>
	<group size="3" rowSize="2" memberDeltaX="64" memberDeltaY="110"/>
	<weapons>
		<weapon name="Lascannon">
			<model>
				<beamWeapon muzzleBone=".MuzzleBone0"/>
			</model>
		</weapon>
	</weapons>
	<modifiers>
		<modifier visible="0">
			<effects>
				<armor base="8"/> <!-- %armor base armor=10/10/10 -->
				<hitpointsMax base="16.0"/> <!-- %hitpointsMax base armor=10/10/10 wounds=2 -->
				<meleeAccuracy base="6"/> <!-- %meleeAccuracy base weaponSkill=3 -->
				<meleeAttacks base="1"/>
				<!-- <meleeInitiative base="3"/> -->
				<oreUpkeep base="6.0"/> <!-- %oreUpkeep base tier=6 factor=1 -->
				<oreCost base="120.0"/> <!-- %oreCost base tier=6 factor=1 -->
				<moraleMax base="10"/> <!-- %moraleMax base leadership=7 -->
				<movementMax base="3"/>
				<productionCost base="54.0"/> <!-- %productionCost base tier=6 factor=1 -->
				<rangedAccuracy base="6"/> <!-- %rangedAccuracy base ballisticSkill=3 -->
			</effects>
		</modifier>
	</modifiers>
	<strategyModifiers>
		<modifier>
			<effects>
				<increaseVehiclesScore base="1.0"/>
			</effects>
		</modifier>
	</strategyModifiers>
	<actions>
		<attack>
			<model>
				<action
						animation="Units/AstraMilitarum/ScoutSentinelAttack"
						beginFire="0.25" endFire="2.9"/>
			</model>				
		</attack>
		<die>
			<model>
				<action animation="Units/AstraMilitarum/ScoutSentinelDie"
						sound="Units/SmallVehicleDie"
						soundCount="3"
						soundDelay="0.45"/>
			</model>		
		</die>
		<idle>
		<model>
			<action animationSpeed="0.75"/>
		</model>
		</idle>
		<move>
			<model>
				<action animation="Units/AstraMilitarum/ScoutSentinelMove"
						sound="Units/AstraMilitarum/ScoutSentinelMove"
						soundCount="1"/>
			</model>				
		</move>
		
		<createSmokeScreen consumedActionPoints="0"
                           consumedMovement="0"
                           cooldown="5"
                           icon="Traits/SmokeScreen"
                           requiredActionPoints="0"
                           requiredUpgrade="AstraMilitarum/SmokeLauncher">
			<model>
				<action sound="Actions/SmokeScreen"/>
			</model>
			<beginTargets>
				<selfTarget>
					<areas>
						<area affects="Tile">
							<modifiers>
								<modifier>
									<effects>
										<addFeature duration="1" name="SmokeScreen"/>
									</effects>
								</modifier>
							</modifiers>
						</area>
					</areas>
				</selfTarget>
			</beginTargets>
		</createSmokeScreen>
	</actions>
	<traits>
		<trait name="CamoNetting" requiredUpgrade="AstraMilitarum/CamoNetting"/>
		<trait name="ExtraVehicleArmour" requiredUpgrade="AstraMilitarum/ExtraVehicleArmour"/>
		<trait name="RecoveryGear" requiredUpgrade="AstraMilitarum/RecoveryGear"/>
		<trait name="MoveThroughCover"/>
		<trait name="PrecisionShots"/>
		<trait name="TrainedSentinelPilots"/>
		<trait name="Vehicle"/>
		<trait name="Walker"/>
		<trait name="OpenTopped"/>
		<trait name="AstraMilitarum/AwakenArmored"/>
		<trait name="MultimodelVehicle"/>
	</traits>
</unit>
