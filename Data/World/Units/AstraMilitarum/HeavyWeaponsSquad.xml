<?xml version="1.0" encoding="utf-8"?>
<unit>
	<model>
		<unit mesh="Units/AstraMilitarum/HeavyWeaponsSquad"
				material="Units/AstraMilitarum/HeavyWeaponsSquad"
				idleAnimation="Units/AstraMilitarum/HeavyWeaponsSquadIdle"
				idleAnimationCount="3"
				idleContinuously="1"
				normalWeight="0.1"
				scale="1 1 1"
				bloodBone="ChestBone"
				walker="1"/>
	</model>
	<group size="4" rowSize="2" memberDeltaX="90" memberDeltaY="100"/>
	<weapons>
		<weapon name="KrakMissileLauncher" slotName="KrakMissileLauncher">
			<model>
				<missileWeapon muzzleBone="Muzzle0"
						fireInterval="0.83"/>
			</model>	
		</weapon>
	</weapons>
	<modifiers>
		<modifier visible="0">
			<effects>
				<armor base="5"/> <!-- %armor base armor=5+ -->
				<foodUpkeep base="2.0"/> <!-- %foodUpkeep base tier=5 factor=1 -->
				<foodCost base="20.0"/> <!-- %foodCost base tier=5 factor=0.5 -->
				<hitpointsMax base="4.0"/> <!-- %hitpointsMax base toughness=3 wounds=2 -->
				<meleeAccuracy base="6"/> <!-- %meleeAccuracy base weaponSkill=3 -->
				<meleeAttacks base="2"/>
				<strengthDamage base="1"/> <!-- %strengthDamage base strength=3 -->
				<!-- <meleeInitiative base="3"/> -->
				<oreCost base="20.0"/> <!-- %oreCost base tier=5 factor=0.5 -->
				<moraleMax base="6"/> <!-- %moraleMax base leadership=6 -->
				<movementMax base="3"/>
				<productionCost base="36.0"/> <!-- %productionCost base tier=5 factor=1 -->
				<rangedAccuracy base="5"/> <!-- %rangedAccuracy base ballisticSkill=3 -->
			</effects>
		</modifier>
	</modifiers>
	<strategyModifiers>
		<modifier>
			<effects>
				<increaseInfantryScore base="1.0"/>
			</effects>
		</modifier>
	</strategyModifiers>
	<actions>
		<attack>
			<model>
				<action	animation="Units/AstraMilitarum/HeavyWeaponsSquadAttack"
						beginFire="0.5"
						endFire="2.4"/>
			</model>			
		</attack>
		<die>
			<model>
				<action	animation="Units/AstraMilitarum/HeavyWeaponsSquadDie"
						sound="Units/MediumUnarmoredDie"
						soundCount="4"
						soundDelay="0.55"
						voiceSound="Units/AstraMilitarum/InfantryDie"
						voiceSoundCount="5"/>
			</model>
		</die>
		<idle>
			<model>
				<action animationSpeed="1.0"/>
			</model>
		</idle>
		<move>
			<model>
				<action	animation="Units/AstraMilitarum/HeavyWeaponsSquadMove"
						sound="Units/AstraMilitarum/InfantryMove"
						soundCount="4"/>
			</model>		
		</move>
		<mediPack cooldown="5" requiredUpgrade="AstraMilitarum/MediPack">
			<model>
				<action bone="ChestBone"
						sound="Actions/Heal"/>
			</model>
			<conditions>
				<unit>
					<damaged/>
                    <noTrait name="SistersOfBattle/HolyFireEnemy"/>
                    <noTrait name="ChaosSpaceMarines/HellFireEnemy"/>
					<noTrait name="SpaceMarines/SalamandersFireEnemy"/>
				</unit>
			</conditions>
			<modifiers>
			<modifier requiredUpgrade="AstraMilitarum/RecoveryGear" visible="1">
				<effects>
					<cooldown add="-2"/>
				</effects>
			</modifier>
			</modifiers>
			<beginTargets>
				<selfTarget>
					<areas>
						<area affects="Unit">
							<modifiers>
								<modifier>
									<effects>
										<hitpointsFactorFromMax add="0.5"/>
									</effects>
								</modifier>
							</modifiers>
						</area>
					</areas>
				</selfTarget>
			</beginTargets>
		</mediPack>
		<createSmokeScreen consumedActionPoints="0"
                           consumedMovement="0"
                           cooldown="5"
                           icon="Traits/SmokeScreen"
                           requiredActionPoints="0">
			<model>
				<action sound="Actions/SmokeScreen"/>
			</model>
			<beginTargets>
				<selfTarget>
					<areas>
						<area affects="Tile">
							<modifiers>
								<modifier>
									<effects>
										<addFeature duration="2" name="SmokeScreen"/>
									</effects>
								</modifier>
							</modifiers>
						</area>
					</areas>
				</selfTarget>
			</beginTargets>
		</createSmokeScreen>
	</actions>
	<traits>
		<trait name="Bulky"/>
		<trait name="AstraMilitarum/DisciplineHeavy"/>
		<trait name="ExtraInfantryArmour" requiredUpgrade="AstraMilitarum/ExtraInfantryArmour"/>
		<trait name="AstraMilitarum/Infantry"/>
		<trait name="MiddleInfantry"/>
		<trait name="RecoveryGear" requiredUpgrade="AstraMilitarum/RecoveryGear"/>
		<trait name="AstraMilitarum/WeStandTogetherScion" requiredUpgrade="AstraMilitarum/WeStandTogether"/>
		<trait name="AstraMilitarum/VoxCasterDies2Morale" requiredUpgrade="AstraMilitarum/VoxCaster"/>
		<trait name="SlowAndPurposeful" requiredUpgrade="AstraMilitarum/SastraMilitaries"/>
	</traits>
</unit>
