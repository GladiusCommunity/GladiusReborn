<?xml version="1.0" encoding="utf-8"?>
<unit>
	<model>		
		<unit mesh="Units/AstraMilitarum/Hydra"
				material="Units/AstraMilitarum/Hydra"
				idleAnimation="Units/AstraMilitarum/HydraIdle"
				idleAnimationCount="2"
				scale="1.2 1.2 1.2"
				explosionsBone="Hull"
				uvAnimated="1"/>
	</model>
	<weapons>
		<weapon name="TwinLinkedHydraAutocannon" count="2">
			<model>
				<projectileWeapon muzzleBone=".Muzzle"
						muzzleCount="4"
						effectFaceWeight="0"/>
			</model>
		</weapon>
		<weapon name="HeavyBolter">
			<model>
				<projectileWeapon mesh="Weapons/AstraMilitarum/HydraHeavyBolter"
						material="Weapons/AstraMilitarum/HydraHeavyBolter"
						bone=".Attachment1"
						muzzleBone=".BolterMuzzle0"/>
			</model>
		</weapon>
		<weapon name="None" enabled="0" requiredUpgrade="AstraMilitarum/SmokeLauncher">
			<model>
				<weapon mesh="Weapons/AstraMilitarum/DozerHydra+"
						material="Units/AstraMilitarum/DozerAM+"
						bone="Hull"/>
			</model>
		</weapon>
	</weapons>
	<modifiers>
		<modifier visible="0">
			<effects>
				<armor base="7"/> <!-- %armor base armor=12/10/10 -->
				<hitpointsMax base="24.0"/> <!-- %hitpointsMax base armor=12/10/10 wounds=3 -->
				<oreUpkeep base="2.0"/> <!-- %oreUpkeep base tier=6 factor=1 -->
				<oreCost base="40.0"/> <!-- %oreCost base tier=6 factor=1 -->
				<moraleMax base="8"/> <!-- %moraleMax base leadership=7 -->
				<movementMax base="4"/>
				<productionCost base="36.0"/> <!-- %productionCost base tier=6 factor=1 -->
				<rangedAccuracy base="6"/> <!-- %rangedAccuracy base ballisticSkill=3 -->
			</effects>
		</modifier>
		<modifier requiredUpgrade="AstraMilitarum/BanebladeLascannon">
		    <effects>
				<movementMax add="1"/>
			</effects>
		</modifier>
	</modifiers>
	<strategyModifiers>
		<modifier>
			<effects>
				<increaseVehiclesScore base="1.0"/>
			</effects>
		</modifier>
	</strategyModifiers>
	<actions>
		<attack>
			<model>
				<action animation="Units/AstraMilitarum/HydraAttack"
						beginFire="0.4" endFire="2.53"/>
			</model>			
		</attack>
		<die>
			<model>
				<action animation="Units/AstraMilitarum/HydraDie"
						sound="Units/MediumVehicleDie"
						soundCount="3"
						soundDelay="0.2"/>
			</model>		
		</die>
		<move>
			<model>
				<action animation="Units/AstraMilitarum/HydraMove"
						sound="Units/AstraMilitarum/TankMove"
						soundCount="3"/>
			</model>		
		</move>
		<createSmokeScreen consumedActionPoints="0"
                           consumedMovement="0"
                           cooldown="5"
                           icon="Traits/SmokeScreen"
                           requiredActionPoints="0"
                           requiredUpgrade="AstraMilitarum/SmokeLauncher">
			<model>
				<action sound="Actions/SmokeScreen"/>
			</model>
			<beginTargets>
				<selfTarget>
					<areas>
						<area affects="Tile">
							<modifiers>
								<modifier>
									<effects>
										<addFeature duration="1" name="SmokeScreen"/>
									</effects>
								</modifier>
							</modifiers>
						</area>
					</areas>
				</selfTarget>
			</beginTargets>
		</createSmokeScreen>
		<genericUnitAbility name="AstraMilitarum/MixCover"
                            passive="1"
                            icon="Traits/AstraMilitarum/MixCover" requiredUpgrade="AstraMilitarum/MixCover">
            <beginTargets>
                <selfTarget>
                    <areas>
                        <area affects="Tile" radius="1">
                            <modifiers>
                                <modifier>
                                    <effects>
                                        <addTrait name="AstraMilitarum/MixCover"/>
                                    </effects>
                                </modifier>
                            </modifiers>
                        </area>
                    </areas>
                </selfTarget>
            </beginTargets>
        </genericUnitAbility>
	</actions>
	<traits>
		<trait name="CamoNetting" requiredUpgrade="AstraMilitarum/CamoNetting"/>
		<trait name="DozerBlade" requiredUpgrade="AstraMilitarum/SmokeLauncher"/>
		<trait name="ExtraVehicleArmour" requiredUpgrade="AstraMilitarum/ExtraVehicleArmour"/>
		<trait name="RecoveryGear" requiredUpgrade="AstraMilitarum/RecoveryGear"/>
		<trait name="RelicPlating" requiredUpgrade="AstraMilitarum/RelicPlating"/>
		<trait name="OpenTopped"/>
		<trait name="Tank"/>
		<trait name="Vehicle"/>
		<trait name="AstraMilitarum/AwakenLeman"/>
	</traits>
</unit>
