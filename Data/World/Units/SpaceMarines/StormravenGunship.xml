<?xml version="1.0" encoding="utf-8"?>
<unit>
	<model>		
		<unit mesh="Units/SpaceMarines/StormravenGunship"
				material="Units/SpaceMarines/StormravenGunship"
				idleAnimation="Units/SpaceMarines/StormravenGunshipIdle"
				idleAnimationCount="2"
				idleContinuously="1"
				position="0 0 64"
				scale="1.0 1.0 1.0"
				normalWeight="1.0"
				explosionsBone="Hull"
				uvAnimated="0"/>
	</model>
	<weapons>
		<weapon name="TwinLinkedAssaultCannon">
			<model>
				<projectileWeapon muzzleBone=".AssaultCannon"/>
			</model>					
		</weapon>
		<weapon name="StormstrikeMissile" slotName="StormstrikeMissile">
			<model>
				<missileWeapon muzzleBone=".StormstrikeMissiles"
						muzzleCount="4"
						fireInterval="1.2"/>
			</model>
		</weapon>
	</weapons>
	<modifiers>
		<modifier visible="0">
			<effects>
				<armor base="8"/> <!-- %armor base armor=12/12/12 -->
				<cargoSlots base="6"/> <!-- %cargoSlots base capacity=12 -->
				<energyUpkeep base="6.0"/> <!-- %energyUpkeep base tier=9 factor=1 -->
				<energyCost base="60.0"/> <!-- %energyCost base tier=9 factor=0.5 -->
				<hitpointsMax base="42.0"/> <!-- %hitpointsMax base armor=12/12/12 wounds=3 -->
				<moraleMax base="12"/> <!-- %moraleMax base leadership=9 -->
				<movementMax base="4"/>
				<productionCost base="54.0"/> <!-- %productionCost base tier=9 factor=1 -->
				<rangedAccuracy base="8"/> <!-- %rangedAccuracy base ballisticSkill=4 -->
				<requisitionsCost base="60.0"/> <!-- %requisitionsCost base tier=9 factor=0.5 -->
			</effects>
		</modifier>
	</modifiers>
	<strategyModifiers>
		<modifier>
			<effects>
				<increaseAircraftScore base="1.0"/>
			</effects>
		</modifier>
	</strategyModifiers>
	<actions>
		<attack>
			<model>
				<action
						animation="Units/SpaceMarines/StormravenGunshipIdle1"
						beginFire="0.2"
						endFire="2.4"/>
			</model>				
		</attack>
		<die>
			<model>
				<action animation="Units/SpaceMarines/StormravenGunshipDie"
						sound="Units/LargeVehicleDie"
						soundCount="3"
						soundDelay="0.1"/>
			</model>		
		</die>
		<move>
			<model>
				<action sound="Units/SpaceMarines/StormravenGunshipMove"
						soundCount="3"/>
			</model>				
		</move>
		<jink consumedActionPoints="0" consumedMovement="0" requiredActionPoints="0" cooldown="3">
			<model>
				<action sound="Actions/ChargeUp"/>
			</model>
			<conditions>
				<unit>
					<notAttackedThisTurn/>
				</unit>
			</conditions>
			<beginTargets>
				<selfTarget>
					<areas>
						<area affects="Unit">
							<modifiers>
								<modifier>
									<effects>
										<addTrait duration="1" name="Jink"/>
									</effects>
								</modifier>
							</modifiers>
						</area>
					</areas>
				</selfTarget>
			</beginTargets>
		</jink>
		<genericUnitAbility name="SpaceMarines/DefensiveFocus"
                            consumedActionPoints="0"
                            consumedMovement="999"
                            cooldown="3"
                            icon="Traits/ExtraInfantryArmour"
                            requiredActionPoints="1">
            <model>
                <action sound="Actions/Reload"/>
            </model>
            <beginTargets>
                <selfTarget>
                    <areas>
                        <area affects="Unit">
                            <modifiers>
                                <modifier>
                                    <effects>
                                        <addTrait name="SpaceMarines/DefensiveFocus"
                                                  duration="1"/>
                                    </effects>
                                </modifier>
                            </modifiers>
                        </area>
                    </areas>
                </selfTarget>
            </beginTargets>
        </genericUnitAbility>
		<genericUnitAbility name="SpaceMarines/DefenseShroud"
				cooldown="5"
				requiredActionPoints="0"
				consumedActionPoints="0" consumedMovement="0">
			<model>
				<action sound="Actions/RavenLauncher"/>
			</model>
			<beginTargets>
				<selfTarget>
					<areas>
						<area affects="Tile" radius="1">
							<modifiers>
								<modifier>
									<conditions>
										<unit>
											<allied/>
											<faction name="SpaceMarines"/>
										</unit>
									</conditions>
									<effects>
										<addFeature duration="1" name="SmokeScreen"/>
									</effects>
								</modifier>
							</modifiers>
						</area>
					</areas>
				</selfTarget>
			</beginTargets>
		</genericUnitAbility>
	</actions>
	<traits>
		<trait name="SpaceMarines/FlyerSight" requiredUpgrade="SpaceMarines/FlyerSight"/>
		<trait name="SpaceMarines/AssignRavenguard" requiredUpgrade="SpaceMarines/ChapterAssign"/>
		<trait name="SpaceMarines/RavenGlory" requiredUpgrade="SpaceMarines/AssaultSpaceMarine"/>
		<trait name="SpaceMarines/RavenGuard"/>
		<trait name="AndTheyShallKnowNoFear"/>
		<trait name="AssaultVehicle"/>
		<trait name="CeramitePlating" requiredUpgrade="SpaceMarines/CeramitePlating"/>
		<trait name="ExtraVehicleArmour" requiredUpgrade="SpaceMarines/ExtraVehicleArmour"/>
		<trait name="LastStand" requiredUpgrade="SpaceMarines/LastStand"/>
		<trait name="LocatorBeacon" requiredUpgrade="SpaceMarines/LocatorBeacon"/>
		<trait name="Flyer"/>
		<!-- <trait name="Hover"/> -->
		<trait name="Transport"/>
		<trait name="Vehicle"/>
	</traits>
</unit>
