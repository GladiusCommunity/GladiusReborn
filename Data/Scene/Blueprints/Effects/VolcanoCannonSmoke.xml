<?xml version="1.0" encoding="utf-8"?>
<simpleParticleSystem material="Effects/VolcanoCannonSmoke"
		particleAlignment="MiddleLeft"
		particleOrientation="AxisBillboarded">
	<updateQueues>
		<updateQueue name="Parallel3"/>
	</updateQueues>
	<renderQueues>
		<renderQueue name="GlowingSimpleParticleSystems"/>
	</renderQueues>

	<emitters>

		<boxEmitter
			particleSizeSquared="0"
			emissionVolumeMin="-1 0 0"
			emissionVolumeMax="0 0 0"
			particleLifeTimeMin="4"
			particleLifeTimeMax="4"
			particleSizeMin="500 500"
			particleSizeMax="500 500"
			particleVelocityMin="0"
			particleVelocityMax="0"
			spawns="1"
			interval="0.001"/>
		
	</emitters>

	<affectors>

<!-- 
		<rotationAffector>
		 	<rotations>
			 	<rotation value="0 1 0 0" progress="0.0"/>
			 	<rotation value="0 1 0 30" progress="1"/>
		 	</rotations>
		</rotationAffector>
 -->

		<colorAffector>
			<colors>
				<color value="1 1 1 1" progress="0.475"/>
				<color value="1 .1 .1 .2" progress="0.5"/>
				<color value="0 0 0 0" progress="0.6"/>
			</colors>
		</colorAffector>

		<scaleAffector>
			<scales>
				<scale value="0 0" progress="0"/>
				<scale value="0 0" progress="0.475"/>
				<scale value="0.5 0.5" progress="0.4751"/>
				<scale value="0 0" progress="0.6"/>
				<scale value="0 0" progress="0.76"/>
				<scale value="0 0" progress="0.9"/>
			</scales>
		</scaleAffector>

	</affectors>
</simpleParticleSystem>
